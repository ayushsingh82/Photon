# Magic Labs — seedless social / email login (https://dashboard.magic.link)
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx

# Particle Network — Universal Accounts (https://dashboard.particle.network)
# The Universal Account SDK runs in the browser, so the app id must be public.
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# DefiLlama Yields API (no key) + Arbitrum RPC for on-chain reads
NEXT_PUBLIC_DEFILLAMA_BASE=https://yields.llama.fi
NEXT_PUBLIC_ARB_RPC=https://arb1.arbitrum.io/rpc
